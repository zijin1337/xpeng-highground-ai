HIGHGROUND_ENV=development
HIGHGROUND_API_KEY=replace-with-a-long-random-value
HIGHGROUND_DATABASE_PATH=./data/highground.db
HIGHGROUND_ACTUATOR_MODE=record-only
HIGHGROUND_AUTH_TTL_SECONDS=120
HIGHGROUND_EVENT_MAX_AGE_SECONDS=300
HIGHGROUND_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
