<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/highground_header"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title"
                    android:textColor="@color/highground_on_header"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/monitor_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_badge_inactive"
                    android:gravity="center"
                    android:minWidth="70dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/monitor_inactive"
                    android:textColor="@color/highground_on_header"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/header_subtitle"
                android:textColor="@color/highground_header_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/safety_boundary_short"
                android:textColor="@color/highground_header_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp">

            <TextView
                style="@style/SectionTitle"
                android:text="@string/current_decision" />

            <LinearLayout
                android:id="@+id/decision_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_decision_neutral"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/decision_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/decision_waiting"
                        android:textColor="@color/highground_text"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/risk_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_risk_neutral"
                        android:gravity="center"
                        android:minWidth="62dp"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:text="@string/risk_waiting"
                        android:textColor="@color/highground_muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/decision_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/decision_reason_empty"
                    android:textColor="@color/highground_text_secondary"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/MetricLabel"
                            android:text="@string/water_level" />

                        <TextView
                            android:id="@+id/water_value"
                            style="@style/MetricValue"
                            android:text="@string/metric_water_empty" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="18dp"
                        android:background="@color/highground_border" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/MetricLabel"
                            android:text="@string/rainfall" />

                        <TextView
                            android:id="@+id/rain_value"
                            style="@style/MetricValue"
                            android:text="@string/metric_rain_empty" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/received_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/received_time_empty"
                    android:textColor="@color/highground_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/refresh_now"
                    style="@style/PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/start_monitor" />

                <Button
                    android:id="@+id/config_toggle"
                    style="@style/SecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/show_connection_settings" />
            </LinearLayout>

            <TextView
                style="@style/SectionTitle"
                android:layout_marginTop="26dp"
                android:text="@string/runtime_status" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_surface_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/StatusLabel"
                    android:text="@string/backend_status" />

                <TextView
                    android:id="@+id/monitor_status"
                    style="@style/StatusValue"
                    android:text="@string/monitor_not_started"
                    android:textIsSelectable="true" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/highground_border" />

                <TextView
                    style="@style/StatusLabel"
                    android:text="@string/xui_capability" />

                <TextView
                    android:id="@+id/xui_status"
                    style="@style/StatusValue"
                    android:text="@string/xui_waiting"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <TextView
                style="@style/SectionTitle"
                android:layout_marginTop="26dp"
                android:text="@string/vehicle_status" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_surface_panel"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/MetricLabel"
                        android:text="@string/speed" />

                    <TextView
                        android:id="@+id/speed_value"
                        style="@style/VehicleValue"
                        android:text="@string/speed_empty" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/MetricLabel"
                        android:text="@string/raw_gear" />

                    <TextView
                        android:id="@+id/gear_value"
                        style="@style/VehicleValue"
                        android:text="@string/value_empty" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1.25"
                    android:orientation="vertical">

                    <TextView
                        style="@style/MetricLabel"
                        android:text="@string/weather" />

                    <TextView
                        android:id="@+id/weather_value"
                        style="@style/VehicleValue"
                        android:maxLines="2"
                        android:text="@string/value_empty" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/config_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="vertical">

                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/backend_connection" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/backend_connection_help"
                    android:textColor="@color/highground_muted"
                    android:textSize="13sp" />

                <TextView
                    style="@style/FormLabel"
                    android:text="@string/api_url_label" />

                <EditText
                    android:id="@+id/api_url"
                    style="@style/FormField"
                    android:hint="@string/api_url_hint"
                    android:importantForAutofill="no"
                    android:inputType="textUri"
                    android:maxLines="1" />

                <TextView
                    style="@style/FormLabel"
                    android:text="@string/api_key_label" />

                <EditText
                    android:id="@+id/api_key"
                    style="@style/FormField"
                    android:hint="@string/api_key_hint"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:maxLines="1" />

                <TextView
                    style="@style/FormLabel"
                    android:text="@string/site_id_label" />

                <EditText
                    android:id="@+id/site_id"
                    style="@style/FormField"
                    android:hint="@string/site_id_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:maxLines="1" />

                <TextView
                    style="@style/FormLabel"
                    android:text="@string/vehicle_id_label" />

                <EditText
                    android:id="@+id/vehicle_id"
                    style="@style/FormField"
                    android:hint="@string/vehicle_id_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:maxLines="1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/start_monitor"
                        style="@style/PrimaryButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1.5"
                        android:text="@string/save_and_start" />

                    <Button
                        android:id="@+id/stop_monitor"
                        style="@style/SecondaryButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="@string/stop" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/SectionTitle"
                android:layout_marginTop="28dp"
                android:text="@string/vehicle_tests" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/test_voice"
                    style="@style/SecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/test_voice" />

                <Button
                    android:id="@+id/test_light"
                    style="@style/SecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/test_light" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/test_light_explanation"
                android:textColor="@color/highground_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
