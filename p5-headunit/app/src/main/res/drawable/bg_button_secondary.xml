<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#E5EFED" />
            <stroke android:width="1dp" android:color="@color/highground_accent" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/highground_panel" />
            <stroke android:width="1dp" android:color="@color/highground_border" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</selector>
